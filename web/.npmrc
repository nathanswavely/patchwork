# Dependency lifecycle scripts do not run on install.
#
# `npm ci` otherwise executes preinstall/install/postinstall from every package
# in the transitive tree, unsandboxed, with full filesystem and network access —
# in CI and inside the Docker frontend stage. That is the shortest path from a
# single compromised npm release to code execution in our build. Nothing in this
# project's own package.json needs a lifecycle script.
#
# Three packages in the tree declare install scripts: esbuild (resolves its
# platform binary, which npm already installs as an optional dependency) and
# fsevents (macOS-only native build, optional). `npm ci && npm run build` is
# verified working with this set to true; if a future dependency genuinely needs
# its script, allow that one package rather than dropping this file.
ignore-scripts=true
